  },
  "homepage": "https://github.com/your-username/claude-code-setup#readme",
  "bin": {
    "claude-setup": "./scripts/main.js"
  },
  "files": [
    "scripts/",
    "config/",
    "templates/",
    "docs/",
    "README.md",
    "LICENSE"
  ]
