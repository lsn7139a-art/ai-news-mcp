# Claude API 配置
ANTHROPIC_API_KEY=your_claude_api_key_here
ANTHROPIC_API_URL=https://api.anthropic.com

# Ollama API 配置
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=minimax-m2:cloud
OLLAMA_TIMEOUT=30

# OpenAI API 配置 (可选)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1

# GitHub API 配置 (可选)
GITHUB_TOKEN=your_github_token_here
GITHUB_API_URL=https://api.github.com

# 代理配置 (可选)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# 开发环境配置
NODE_ENV=development
DEBUG=false
LOG_LEVEL=info

# 项目配置
PROJECT_NAME=Claude Code Setup
PROJECT_VERSION=1.0.0
AUTHOR=Your Name

# 工具配置
DEFAULT_EDITOR=code
DEFAULT_BROWSER=chrome
DEFAULT_TERMINAL=powershell

# 路径配置
WORKSPACE_PATH=d:\AI\Claude code
TEMPLATES_PATH=d:\AI\Claude code\templates
SCRIPTS_PATH=d:\AI\Claude code\scripts
DOCS_PATH=d:\AI\Claude code\docs

# API 限制配置
MAX_REQUESTS_PER_MINUTE=60
MAX_TOKENS_PER_REQUEST=4096
TIMEOUT_SECONDS=30

# 缓存配置
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_DIR=d:\AI\Claude code\.cache

# 日志配置
LOG_FILE=d:\AI\Claude code\logs\app.log
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=5

# 安全配置
ENABLE_ENCRYPTION=false
SSL_VERIFY=true
API_KEY_ENCRYPTION=false